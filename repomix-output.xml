        await fs.mkdir(projectPath, { recursive: true });
        
        // Create test MCP server
        await createTestMCPServer(serverPath);
    });

    afterEach(async () => {
        // Shutdown service
        await service.shutdown();

        // Clean up test files
        await fs.rm(testDir, { recursive: true, force: true });
