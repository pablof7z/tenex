  CHAT: "chat" as const,
  BRAINSTORM: "brainstorm" as const,
  PLAN: "plan" as const,
  EXECUTE: "execute" as const,
  VERIFICATION: "verification" as const,
  CHORES: "chores" as const,
  REFLECTION: "reflection" as const,
} as const;

export const ALL_PHASES: readonly Phase[] = [
  PHASES.CHAT,
  PHASES.BRAINSTORM,
  PHASES.PLAN,
  PHASES.EXECUTE,
  PHASES.VERIFICATION,
  PHASES.CHORES,
