            const name2 = spawnCalls[1][0];

            expect(name1).toMatch(/^cli-\d+$/);
            expect(name2).toMatch(/^cli-\d+$/);
            expect(name1).not.toBe(name2);
        });

        test("should handle invalid JSON response", async () => {
