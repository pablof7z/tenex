                "pm-agent-1",
                "PM Agent",
                "moving to planning"
            );

            // Second transition: plan -> execute
            await manager.updatePhase(
                conversation.id,
                "execute",
                "Plan: 1. Setup project 2. Implement commands 3. Add tests",
                "pm-agent-1",
                "PM Agent",
                "plan approved"
