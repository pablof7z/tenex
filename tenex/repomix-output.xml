                    },
                    "global-server2": {
                        command: "python",
                        args: ["global2.py"],
                        allowedPaths: ["/global/path"],
                    },
                },
                enabled: true,
            },
        };

        mockProjectConfig = {
            mcp: {
                servers: {
                    "project-server1": {
                        command: "bun",
                        args: ["project1.ts"],
                        description: "Project server 1",
                        env: { API_KEY: "secret" },
                    },
                    "project-server2": {
                        command: "deno",
                        args: ["run", "project2.ts"],
