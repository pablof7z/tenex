            (configService.getProjectPath as any).mockReturnValue(undefined);

            await program.parseAsync(["node", "test", "mcp", "list", "--project"]);

            expect(mockConsoleLog).toHaveBeenCalledWith(
                chalk.yellow("Not in a TENEX project directory")
