                servers: {
                    "test": {
                        command: "node",
                        args: ["test.js"],
                    },
                },
                enabled: false,
            };

            const result = TenexMCPSchema.safeParse(config);
            expect(result.success).toBe(true);
            if (result.success) {
                expect(result.data.enabled).toBe(false);
            }
        });

        it("should reject invalid server configurations", () => {
